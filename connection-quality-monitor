    throughput_mbps REAL,
    error TEXT,
    created_at_utc TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ', 'now'))
);

CREATE INDEX IF NOT EXISTS idx_samples_timestamp ON samples(timestamp_utc);
CREATE INDEX IF NOT EXISTS idx_samples_check_target ON samples(check_type, target);

CREATE TABLE IF NOT EXISTS metadata (
    key TEXT PRIMARY KEY,
    value TEXT NOT NULL,
    updated_at_utc TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ', 'now'))
);
"""
STOP = False


def now_utc() -> dt.datetime:
    return dt.datetime.now(dt.timezone.utc)


def iso_local(t: Optional[dt.datetime] = None) -> str:
    if t is None:
        t = now_utc()
    return t.astimezone().isoformat(timespec="seconds")


def as_float(value: Any) -> Optional[float]:
    try:
        return float(value)
    except Exception:
        return None


def split_csv(value: str) -> List[str]:
    return [x.strip() for x in value.split(",") if x.strip()]


def handle_signal(signum: int, frame: Any) -> None:  # noqa: ARG001
    global STOP
    STOP = True


def run_ping(target: str, count: int, timeout_s: float) -> Dict[str, Any]:
    if shutil.which("ping") is None:
        return result("ping", target, False, error="ping binary not found")

    # Linux ping: -n numeric, -c count, -W per-reply timeout seconds.
    # macOS/BSD compatibility is best-effort; the Linux path is the intended server case.
    timeout_arg = str(max(1, int(round(timeout_s))))
    cmd = ["ping", "-n", "-c", str(count), "-W", timeout_arg, target]
    start = time.monotonic()
    try:
        proc = subprocess.run(cmd, text=True, capture_output=True, timeout=count * timeout_s + 3)
    except subprocess.TimeoutExpired as e:
        elapsed = (time.monotonic() - start) * 1000
        return result("ping", target, False, latency_ms=elapsed, error=f"ping timeout: {e}")
    except Exception as e:
        return result("ping", target, False, error=str(e))

    output = (proc.stdout or "") + "\n" + (proc.stderr or "")
    packet_loss = None
    loss_match = re.search(r"([0-9]+(?:\.[0-9]+)?)%\s*packet loss", output)
    if loss_match:
        packet_loss = float(loss_match.group(1))

    # Linux: rtt min/avg/max/mdev = 6.917/7.312/7.926/0.290 ms
    # BusyBox can print: round-trip min/avg/max = ...
    latency_ms = None
    jitter_ms = None
    rtt_match = re.search(r"(?:rtt|round-trip).*?=\s*([0-9.]+)/([0-9.]+)/([0-9.]+)(?:/([0-9.]+))?\s*ms", output)
    if rtt_match:
        latency_ms = float(rtt_match.group(2))
        jitter_ms = float(rtt_match.group(4)) if rtt_match.group(4) else (float(rtt_match.group(3)) - float(rtt_match.group(1)))
    else:
        times = [float(x) for x in re.findall(r"time=([0-9.]+)\s*ms", output)]
        if times:
            latency_ms = statistics.mean(times)
            jitter_ms = statistics.pstdev(times) if len(times) > 1 else 0.0

    ok = proc.returncode == 0 and (packet_loss is None or packet_loss < 100) and latency_ms is not None
    err = None if ok else compact_error(output) or f"ping exited {proc.returncode}"
    return result("ping", target, ok, latency_ms=latency_ms, jitter_ms=jitter_ms, packet_loss_pct=packet_loss, error=err)


def compact_error(text: str, limit: int = 220) -> str:
    text = " ".join(line.strip() for line in text.splitlines() if line.strip())
    return text[:limit]


def run_dns(host: str, timeout_s: float) -> Dict[str, Any]:
    old_timeout = socket.getdefaulttimeout()
    socket.setdefaulttimeout(timeout_s)
    start = time.monotonic()
    try:
        answers = socket.getaddrinfo(host, 443, type=socket.SOCK_STREAM)
        elapsed = (time.monotonic() - start) * 1000
        return result("dns", host, bool(answers), latency_ms=elapsed, bytes=len(answers))
    except Exception as e:
        elapsed = (time.monotonic() - start) * 1000
        return result("dns", host, False, latency_ms=elapsed, error=str(e))
    finally:
        socket.setdefaulttimeout(old_timeout)


def run_http(url: str, timeout_s: float) -> Dict[str, Any]:
    start = time.monotonic()
    req = urllib.request.Request(url, method="GET", headers={"User-Agent": "connection-quality-monitor/1.0"})
    try:
        with urllib.request.urlopen(req, timeout=timeout_s) as resp:
            # Read a tiny amount to make sure the response body starts arriving.
            data = resp.read(4096)
            elapsed = (time.monotonic() - start) * 1000
            status = getattr(resp, "status", None)
            return result("http", url, 200 <= int(status or 0) < 400, latency_ms=elapsed, status_code=status, bytes=len(data))
    except Exception as e:
        elapsed = (time.monotonic() - start) * 1000
        return result("http", url, False, latency_ms=elapsed, error=str(e))


def run_download(url: str, timeout_s: float, max_bytes: int) -> Dict[str, Any]:
    start = time.monotonic()
    req = urllib.request.Request(url, headers={"User-Agent": "connection-quality-monitor/1.0"})
    total = 0
    status = None
    try:
        with urllib.request.urlopen(req, timeout=timeout_s) as resp:
            status = getattr(resp, "status", None)
            while total < max_bytes:
                chunk = resp.read(min(65536, max_bytes - total))
                if not chunk:
                    break
                total += len(chunk)
        elapsed_s = max(time.monotonic() - start, 0.001)
        mbps = (total * 8) / elapsed_s / 1_000_000
        ok = total > 0 and 200 <= int(status or 0) < 400
        return result("download", url, ok, latency_ms=elapsed_s * 1000, status_code=status, bytes=total, throughput_mbps=mbps)
    except Exception as e:
        elapsed_s = max(time.monotonic() - start, 0.001)
        mbps = (total * 8) / elapsed_s / 1_000_000 if total else None
        return result("download", url, False, latency_ms=elapsed_s * 1000, status_code=status, bytes=total, throughput_mbps=mbps, error=str(e))


def result(check_type: str, target: str, ok: bool, **kwargs: Any) -> Dict[str, Any]:
    t = now_utc()
    row: Dict[str, Any] = {
        "timestamp_utc": t.isoformat(timespec="seconds"),
        "local_time": iso_local(t),
        "check_type": check_type,
        "target": target,
        "ok": bool(ok),
        "latency_ms": None,
        "jitter_ms": None,
        "packet_loss_pct": None,
        "status_code": None,
        "bytes": None,
        "throughput_mbps": None,
        "error": None,
    }
    row.update(kwargs)
    for key in ("latency_ms", "jitter_ms", "packet_loss_pct", "throughput_mbps"):
        if row.get(key) is not None:
            row[key] = round(float(row[key]), 3)
    return row


def sample(args: argparse.Namespace) -> List[Dict[str, Any]]:
    rows: List[Dict[str, Any]] = []
    for target in args.ping_targets:
        rows.append(run_ping(target, args.ping_count, args.timeout))
    for host in args.dns_hosts:
        rows.append(run_dns(host, args.timeout))
    for url in args.http_urls:
        rows.append(run_http(url, args.timeout))
    if args.download_url and args.download_bytes > 0:
        rows.append(run_download(args.download_url, args.timeout, args.download_bytes))
    return rows


def ensure_outputs(out_dir: Path) -> Tuple[Path, Path]:
    out_dir.mkdir(parents=True, exist_ok=True)
    day = dt.datetime.now().strftime("%Y-%m-%d")
    return out_dir / f"connection-quality-{day}.csv", out_dir / f"connection-quality-{day}.jsonl"


def append_rows(out_dir: Path, rows: Iterable[Dict[str, Any]]) -> None:
    csv_path, jsonl_path = ensure_outputs(out_dir)
    csv_exists = csv_path.exists()
    with csv_path.open("a", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=CSV_FIELDS)
        if not csv_exists:
            writer.writeheader()
        for row in rows:
            writer.writerow({k: row.get(k) for k in CSV_FIELDS})
    with jsonl_path.open("a", encoding="utf-8") as f:
        for row in rows:
            f.write(json.dumps(row, sort_keys=True) + "\n")


def init_sqlite(db_path: Path) -> None:
    db_path.parent.mkdir(parents=True, exist_ok=True)
    with sqlite3.connect(db_path) as conn:
        conn.executescript(SQLITE_SCHEMA)


def append_rows_sqlite(db_path: Path, rows: Iterable[Dict[str, Any]]) -> None:
    init_sqlite(db_path)
    values = []
    for row in rows:
        values.append(
            (
                row.get("timestamp_utc"),
                row.get("local_time"),
                row.get("check_type"),
                row.get("target"),
                1 if row.get("ok") else 0,
                row.get("latency_ms"),
                row.get("jitter_ms"),
                row.get("packet_loss_pct"),
                row.get("status_code"),
                row.get("bytes"),
                row.get("throughput_mbps"),
                row.get("error"),
            )
        )
    if not values:
        return
    with sqlite3.connect(db_path) as conn:
        conn.executemany(
            """
            INSERT INTO samples (
                timestamp_utc, local_time, check_type, target, ok,
                latency_ms, jitter_ms, packet_loss_pct, status_code,
                bytes, throughput_mbps, error
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            values,
        )


def write_metadata_sqlite(db_path: Path, args: argparse.Namespace) -> None:
    init_sqlite(db_path)
    metadata = {
        "created_utc": now_utc().isoformat(timespec="seconds"),
        "host": socket.gethostname(),
        "platform": platform.platform(),
        "python": sys.version.split()[0],
        "config": json.dumps(
            {
                "interval": args.interval,
                "timeout": args.timeout,
                "ping_targets": args.ping_targets,
                "dns_hosts": args.dns_hosts,
                "http_urls": args.http_urls,
                "download_url": args.download_url,
                "download_bytes": args.download_bytes,
                "ping_count": args.ping_count,
                "storage": args.storage,
            },
            sort_keys=True,
        ),
    }
    with sqlite3.connect(db_path) as conn:
        conn.executemany(
            """
            INSERT INTO metadata(key, value, updated_at_utc)
            VALUES (?, ?, strftime('%Y-%m-%dT%H:%M:%SZ', 'now'))
            ON CONFLICT(key) DO UPDATE SET
                value = excluded.value,
                updated_at_utc = excluded.updated_at_utc
            """,
            metadata.items(),
        )


def round_or_none(value: Any, digits: int = 3) -> Optional[float]:
    if value is None:
        return None
    return round(float(value), digits)


def build_report(db_path: Path, since: str = "", limit_series: int = 2000) -> Dict[str, Any]:
    init_sqlite(db_path)
    where = "WHERE timestamp_utc >= ?" if since else ""
    params: Tuple[Any, ...] = (since,) if since else ()
    with sqlite3.connect(db_path) as conn:
        conn.row_factory = sqlite3.Row
        totals = conn.execute(
            f"""
            SELECT COUNT(*) AS total_samples,
                   SUM(CASE WHEN ok THEN 0 ELSE 1 END) AS failure_count,
                   MIN(timestamp_utc) AS start_time,
                   MAX(timestamp_utc) AS end_time
            FROM samples {where}
            """,
            params,
        ).fetchone()
        by_check_rows = conn.execute(
            f"""
            SELECT check_type,
                   COUNT(*) AS samples,
                   SUM(CASE WHEN ok THEN 0 ELSE 1 END) AS failures,
                   AVG(latency_ms) AS latency_avg_ms,
                   MIN(latency_ms) AS latency_min_ms,
                   MAX(latency_ms) AS latency_max_ms,
                   AVG(packet_loss_pct) AS packet_loss_avg_pct,
                   AVG(throughput_mbps) AS throughput_avg_mbps
            FROM samples {where}
            GROUP BY check_type
            ORDER BY check_type
            """,
            params,
        ).fetchall()
        by_target_rows = conn.execute(
            f"""
            SELECT check_type, target,
                   COUNT(*) AS samples,
                   SUM(CASE WHEN ok THEN 0 ELSE 1 END) AS failures,
                   AVG(latency_ms) AS latency_avg_ms,
                   AVG(packet_loss_pct) AS packet_loss_avg_pct,
                   AVG(throughput_mbps) AS throughput_avg_mbps
            FROM samples {where}
            GROUP BY check_type, target
            ORDER BY check_type, target
            """,
            params,
        ).fetchall()
        series_rows = conn.execute(
            f"""
            SELECT timestamp_utc, check_type, target, ok, latency_ms,
                   packet_loss_pct, throughput_mbps, error
            FROM samples {where}
            ORDER BY timestamp_utc DESC, id DESC
            LIMIT ?
            """,
            (*params, limit_series),
        ).fetchall()
        recent_failures = conn.execute(
            f"""
            SELECT timestamp_utc, check_type, target, latency_ms, packet_loss_pct, error
            FROM samples {where} AND ok = 0
            ORDER BY timestamp_utc DESC, id DESC
            LIMIT 20
            """ if since else """
            SELECT timestamp_utc, check_type, target, latency_ms, packet_loss_pct, error
            FROM samples WHERE ok = 0
            ORDER BY timestamp_utc DESC, id DESC
            LIMIT 20
            """,
            params,
        ).fetchall()

    total_samples = int(totals["total_samples"] or 0)
    failure_count = int(totals["failure_count"] or 0)
    report = {
        "database": str(db_path),
        "generated_utc": now_utc().isoformat(timespec="seconds"),
        "total_samples": total_samples,
        "failure_count": failure_count,
        "failure_pct": round((failure_count / total_samples * 100), 3) if total_samples else 0.0,
        "time_range": {"start": totals["start_time"], "end": totals["end_time"]},
        "by_check_type": {},
        "by_target": [],
        "recent_failures": [dict(row) for row in recent_failures],
        "series": [dict(row) for row in reversed(series_rows)],
    }
    for row in by_check_rows:
        samples = int(row["samples"] or 0)
        failures = int(row["failures"] or 0)
        report["by_check_type"][row["check_type"]] = {
            "samples": samples,
            "failures": failures,
            "failure_pct": round((failures / samples * 100), 3) if samples else 0.0,
            "latency_avg_ms": round_or_none(row["latency_avg_ms"]),
            "latency_min_ms": round_or_none(row["latency_min_ms"]),
            "latency_max_ms": round_or_none(row["latency_max_ms"]),
            "packet_loss_avg_pct": round_or_none(row["packet_loss_avg_pct"]),
            "throughput_avg_mbps": round_or_none(row["throughput_avg_mbps"]),
        }
    for row in by_target_rows:
        samples = int(row["samples"] or 0)
        failures = int(row["failures"] or 0)
        report["by_target"].append(
            {
                "check_type": row["check_type"],
                "target": row["target"],
                "samples": samples,
                "failures": failures,
                "failure_pct": round((failures / samples * 100), 3) if samples else 0.0,
                "latency_avg_ms": round_or_none(row["latency_avg_ms"]),
                "packet_loss_avg_pct": round_or_none(row["packet_loss_avg_pct"]),
                "throughput_avg_mbps": round_or_none(row["throughput_avg_mbps"]),
            }
        )
    return report


def format_report_text(report: Dict[str, Any]) -> str:
    lines = [
        "Connection Quality Report",
        f"Database: {report['database']}",
        f"Generated UTC: {report['generated_utc']}",
        f"Range: {report['time_range']['start']} -> {report['time_range']['end']}",
        f"Samples: {report['total_samples']} | Failures: {report['failure_count']} ({report['failure_pct']}%)",
        "",
        "By check type:",
    ]
    for check_type, stats in report["by_check_type"].items():
        parts = [
            f"- {check_type}: samples={stats['samples']}",
            f"failures={stats['failures']} ({stats['failure_pct']}%)",
        ]
        if stats.get("latency_avg_ms") is not None:
            parts.append(f"avg_latency={stats['latency_avg_ms']}ms")
        if stats.get("packet_loss_avg_pct") is not None:
            parts.append(f"avg_loss={stats['packet_loss_avg_pct']}%")
        if stats.get("throughput_avg_mbps") is not None:
            parts.append(f"avg_throughput={stats['throughput_avg_mbps']}Mbps")
        lines.append(" | ".join(parts))
    if report.get("recent_failures"):
        lines.extend(["", "Recent failures:"])
        for failure in report["recent_failures"][:10]:
            lines.append(f"- {failure['timestamp_utc']} {failure['check_type']} {failure['target']}: {failure.get('error') or 'failed'}")
    return "\n".join(lines)


