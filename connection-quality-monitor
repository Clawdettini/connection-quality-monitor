SQLITE_SCHEMA = """
CREATE TABLE IF NOT EXISTS samples (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    timestamp_utc TEXT NOT NULL,
    local_time TEXT NOT NULL,
    check_type TEXT NOT NULL,
    target TEXT NOT NULL,
    ok INTEGER NOT NULL,
